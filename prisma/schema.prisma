generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum EntityAliasType {
  project
  person
  topic
  tool
  event
  media
  observation
  emotion
}

enum UserInsightCategory {
  insecurity
  fear
  achievement
  strength
  weakness
  value
  belief
  goal
  dream
  preference
  relationship_pattern
  habit
  other
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  entries   JournalEntry[]
  projects  Project[]
  people    Person[]
  aliases   EntityAlias[]
  tags      Tag[]
  insights  UserInsight[]

  @@map("users")
}

model JournalEntry {
  id            String                @id @default(cuid())
  userId        String
  entryDate     DateTime
  rawText       String
  summary       String?
  topics        Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  tools         Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  events        Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  media         Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  observations  Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  emotions      Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  actionItems   Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  lessons       Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  ideas         Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  experiences   Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  workKnowledge Json                  @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  embedding     Unsupported("vector")?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  entryProjects JournalEntryProject[]
  entryPeople   JournalEntryPerson[]
  insights      UserInsight[]

  @@unique([userId, entryDate])
  @@index([userId])
  @@index([entryDate])
  @@map("journal_entries")
}

model Project {
  id             String                @id @default(cuid())
  userId         String
  canonicalName  String
  displayName    String
  description    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntries JournalEntryProject[]

  @@unique([userId, canonicalName])
  @@map("projects")
}

model Person {
  id             String               @id @default(cuid())
  userId         String
  canonicalName  String
  displayName    String
  notes          String?
  birthday       DateTime?            @db.Date
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntries JournalEntryPerson[]
  tags           PersonTag[]

  @@unique([userId, canonicalName])
  @@map("people")
}

model Tag {
  id            String      @id @default(cuid())
  userId        String
  canonicalName String
  displayName   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  people        PersonTag[]

  @@unique([userId, canonicalName])
  @@index([userId])
  @@map("tags")
}

model PersonTag {
  personId String
  tagId    String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([personId, tagId])
  @@index([tagId])
  @@map("person_tags")
}

model EntityAlias {
  id            String          @id @default(cuid())
  userId        String
  entityType    EntityAliasType
  alias         String
  canonicalName String
  displayName   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, alias])
  @@index([userId])
  @@index([entityType])
  @@index([canonicalName])
  @@map("entity_aliases")
}

model JournalEntryProject {
  journalEntryId String
  projectId      String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([journalEntryId, projectId])
  @@map("journal_entry_projects")
}

model JournalEntryPerson {
  journalEntryId String
  personId       String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  person         Person       @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([journalEntryId, personId])
  @@map("journal_entry_people")
}

model UserInsight {
  id             String              @id @default(cuid())
  userId         String
  journalEntryId String?
  category       UserInsightCategory
  content        String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry?       @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([journalEntryId])
  @@map("user_insights")
}
